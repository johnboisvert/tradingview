# ============================================================================
# 🔧 CryptoIA Trading Platform - Configuration
# Copiez ce fichier vers .env et remplissez vos valeurs
# ============================================================================

# 🌐 ENVIRONNEMENT
ENV=production
DEBUG=false
BASE_URL=https://your-domain.com

# 🔐 SÉCURITÉ (OBLIGATOIRE)
# Générez avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-characters
WEBHOOK_SECRET=your-tradingview-webhook-secret

# 💾 BASE DE DONNÉES
# PostgreSQL (recommandé pour production)
DATABASE_URL=postgresql://user:password@host:5432/database
# Ou laissez vide pour utiliser SQLite

# 💳 STRIPE (Paiements par carte)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs pour les abonnements
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_3MONTHS=price_...
STRIPE_PRICE_6MONTHS=price_...
STRIPE_PRICE_YEARLY=price_...

# 💳 COINBASE COMMERCE (Paiements crypto)
COINBASE_COMMERCE_KEY=your-coinbase-api-key
COINBASE_WEBHOOK_SECRET=your-coinbase-webhook-secret

# 📱 TELEGRAM (Alertes)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# 🤖 OPENAI (Fonctions IA)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# 📧 SENDGRID (Emails)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# 📊 APIs CRYPTO (Optionnel - pour plus de requêtes)
COINGECKO_PRO_API_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
CRYPTOCOMPARE_API_KEY=

# ⏰ CACHE (Optionnel)
CACHE_TTL_PRICES=60
CACHE_TTL_MARKET_DATA=300
CACHE_TTL_FEAR_GREED=3600

# 📝 LOGGING
LOG_LEVEL=INFO

# 🔐 SESSION
SESSION_EXPIRE_HOURS=24
BCRYPT_ROUNDS=12
