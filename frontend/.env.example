# ============================================================
# CryptoIA Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Admin Panel Credentials (REQUIRED for /admin access)
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# Google Gemini AI API Key (REQUIRED for AI Assistant)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Backend API Base URL (optional, defaults to http://127.0.0.1:8000)
VITE_API_BASE_URL=

# Sentry Error Monitoring (optional — leave empty to disable Sentry)
# Get yours at: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=
# Tag releases with the deployment commit SHA (set automatically by Railway)
VITE_RELEASE=

# Dev server port (optional, defaults to 3000)
VITE_PORT=3000